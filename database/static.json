    {
      "id": 4,
      "title": "Preguntas Frecuentes",
      "slug": "faqs",
      "content": [
        { "type": "paragraph", "children": [ { "type": "text", "text": "<section id=\"faq-section\" class=\"faq-section\"><div class=\"faq-container\"><div class=\"faq-column\">" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Cómo puedo empezar?\" data-contenido=\"Solo tienes que seleccionar el plan que mejor se adapte a ti y completar el proceso de alta online.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Qué formas de pago aceptáis?\" data-contenido=\"Puedes realizar tus pagos de forma segura mediante tarjeta bancaria o a través de nuestra pasarela de pago.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Existe algún compromiso de permanencia?\" data-contenido=\"Nuestros servicios son flexibles. Puedes darte de baja cuando lo desees sin costes adicionales.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Puedo modificar mi suscripción?\" data-contenido=\"Sí, puedes cambiar o actualizar los detalles de tu cuenta en cualquier momento desde tu área de usuario.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "</div><div class=\"faq-column\">" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Necesito experiencia previa?\" data-contenido=\"No es necesario. Nuestros contenidos y servicios están diseñados para adaptarse a todos los niveles.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Qué incluye mi suscripción?\" data-contenido=\"Tendrás acceso completo a todas las funcionalidades y recursos detallados en el plan que hayas elegido.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Cómo puedo resolver mis dudas?\" data-contenido=\"Nuestro equipo de atención al cliente está disponible para ayudarte a través de nuestro canal de contacto directo.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "<div data-xlu-include-file=\"./templates/faqs.html\" data-titulo=\"¿Los precios incluyen impuestos?\" data-contenido=\"Sí, todos los precios mostrados en nuestra web incluyen los impuestos correspondientes según la normativa vigente.\"></div>" } ] },
        { "type": "paragraph", "children": [ { "type": "text", "text": "</div></div></section>" } ] }
      ]
